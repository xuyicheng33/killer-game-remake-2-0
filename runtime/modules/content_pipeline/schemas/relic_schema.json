{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relic Data Schema",
  "description": "遗物数据定义 schema",
  "type": "object",
  "required": ["schema_version", "relics"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema 版本号",
      "minimum": 1,
      "default": 1
    },
    "relics": {
      "type": "array",
      "description": "遗物定义列表",
      "items": {
        "$ref": "#/definitions/relic"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "relic": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "description": "遗物唯一标识符",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "title": {
          "type": "string",
          "description": "遗物显示名称",
          "minLength": 1,
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "description": "遗物描述文本",
          "maxLength": 512
        },
        "art_path": {
          "type": "string",
          "description": "遗物图片资源路径",
          "pattern": "^res://"
        },
        "rarity": {
          "type": "string",
          "description": "稀有度",
          "enum": ["common", "uncommon", "rare", "boss", "special", "starter"],
          "default": "common"
        },
        "effects": {
          "type": "object",
          "description": "遗物效果配置",
          "properties": {
            "on_battle_start_heal": {
              "type": "integer",
              "description": "战斗开始时恢复的生命值",
              "minimum": 0,
              "default": 0
            },
            "on_card_played_gold": {
              "type": "integer",
              "description": "每打出N张牌获得的金币数",
              "minimum": 0,
              "default": 0
            },
            "card_play_interval": {
              "type": "integer",
              "description": "触发金币奖励的卡牌间隔",
              "minimum": 1,
              "default": 1
            },
            "on_player_hit_block": {
              "type": "integer",
              "description": "格挡时对攻击者造成的伤害",
              "minimum": 0,
              "default": 0
            },
            "on_enemy_killed_gold": {
              "type": "integer",
              "description": "击杀敌人时获得的金币",
              "minimum": 0,
              "default": 0
            },
            "on_turn_start_block": {
              "type": "integer",
              "description": "每回合开始时获得的格挡值",
              "minimum": 0,
              "default": 0
            },
            "on_turn_end_heal": {
              "type": "integer",
              "description": "每回合结束时恢复的生命值",
              "minimum": 0,
              "default": 0
            },
            "shop_discount_percent": {
              "type": "integer",
              "description": "商店折扣百分比（0-90）",
              "minimum": 0,
              "maximum": 90,
              "default": 0
            },
            "on_run_start_gold": {
              "type": "integer",
              "description": "游戏开始时获得的金币",
              "minimum": 0,
              "default": 0
            },
            "on_run_start_max_health": {
              "type": "integer",
              "description": "游戏开始时提升的最大生命值",
              "minimum": 0,
              "default": 0
            }
          },
          "additionalProperties": false
        },
        "tags": {
          "type": "array",
          "description": "遗物标签",
          "items": {
            "type": "string",
            "enum": ["starter", "obtainable", "special"]
          }
        },
        "starter": {
          "type": "boolean",
          "description": "是否为开局遗物",
          "default": false
        }
      },
      "additionalProperties": false
    }
  }
}
