{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Potion Data Schema",
  "description": "药水数据定义 schema",
  "type": "object",
  "required": ["schema_version", "potions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema 版本号",
      "minimum": 1,
      "default": 1
    },
    "potions": {
      "type": "array",
      "description": "药水定义列表",
      "items": {
        "$ref": "#/definitions/potion"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "potion": {
      "type": "object",
      "required": ["id", "title", "effect_type", "value"],
      "properties": {
        "id": {
          "type": "string",
          "description": "药水唯一标识符",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "title": {
          "type": "string",
          "description": "药水显示名称",
          "minLength": 1,
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "description": "药水描述文本",
          "maxLength": 512
        },
        "art_path": {
          "type": "string",
          "description": "药水图片资源路径",
          "pattern": "^res://"
        },
        "effect_type": {
          "type": "string",
          "description": "效果类型",
          "enum": ["heal", "gold", "block", "damage_all_enemies"]
        },
        "value": {
          "type": "integer",
          "description": "效果数值",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
