{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Enemy Data Schema",
  "description": "敌人数据定义 schema，支持单个敌人配置和遭遇组合配置",
  "type": "object",
  "required": ["schema_version", "enemies"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Schema 版本号",
      "minimum": 1,
      "default": 1
    },
    "enemies": {
      "type": "array",
      "description": "敌人定义列表",
      "items": {
        "$ref": "#/definitions/enemy"
      },
      "minItems": 1
    },
    "encounters": {
      "type": "array",
      "description": "遭遇组合定义列表",
      "items": {
        "$ref": "#/definitions/encounter"
      }
    }
  },
  "definitions": {
    "enemy": {
      "type": "object",
      "required": ["id", "max_health"],
      "properties": {
        "id": {
          "type": "string",
          "description": "敌人唯一标识符",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "name": {
          "type": "string",
          "description": "敌人显示名称",
          "minLength": 1,
          "maxLength": 64
        },
        "max_health": {
          "type": "integer",
          "description": "最大生命值",
          "minimum": 1,
          "maximum": 9999
        },
        "art_path": {
          "type": "string",
          "description": "敌人图片资源路径",
          "pattern": "^res://"
        },
        "ai_scene_path": {
          "type": "string",
          "description": "敌人 AI PackedScene 路径",
          "pattern": "^res://"
        },
        "intents": {
          "type": "array",
          "description": "敌人意图列表",
          "items": {
            "$ref": "#/definitions/intent"
          },
          "minItems": 1
        },
        "tags": {
          "type": "array",
          "description": "敌人标签",
          "items": {
            "type": "string",
            "enum": ["common", "elite", "boss"]
          }
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "意图名称",
          "minLength": 1,
          "maxLength": 64
        },
        "type": {
          "type": "string",
          "description": "意图类型",
          "enum": ["conditional", "chance_based"]
        },
        "weight": {
          "type": "number",
          "description": "权重（仅 chance_based 类型需要）",
          "minimum": 0,
          "maximum": 1000
        },
        "condition": {
          "type": "string",
          "description": "条件表达式（仅 conditional 类型需要）",
          "maxLength": 256
        },
        "effects": {
          "type": "array",
          "description": "意图效果列表",
          "items": {
            "$ref": "#/definitions/effect"
          }
        },
        "disallow_consecutive": {
          "type": "boolean",
          "description": "是否禁止连续使用相同意图",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "effect": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": {
          "type": "string",
          "description": "操作类型",
          "enum": ["damage", "block", "apply_status", "heal"]
        },
        "amount": {
          "type": "integer",
          "description": "数值",
          "minimum": 0
        },
        "status_id": {
          "type": "string",
          "description": "状态 ID（apply_status 时需要）",
          "minLength": 1
        },
        "stacks": {
          "type": "integer",
          "description": "层数（apply_status 时需要）",
          "minimum": 1
        },
        "target": {
          "type": "string",
          "description": "目标",
          "enum": ["player", "self"],
          "default": "player"
        }
      },
      "additionalProperties": false
    },
    "encounter": {
      "type": "object",
      "required": ["id", "enemies"],
      "properties": {
        "id": {
          "type": "string",
          "description": "遭遇唯一标识符",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "enemies": {
          "type": "array",
          "description": "敌人 ID 列表",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 5
        },
        "weight": {
          "type": "integer",
          "description": "遭遇权重",
          "minimum": 1,
          "default": 1
        },
        "floor_range": {
          "type": "object",
          "description": "出现楼层范围",
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "max": {
              "type": "integer",
              "minimum": 0,
              "default": 999
            }
          }
        },
        "tags": {
          "type": "array",
          "description": "遭遇标签",
          "items": {
            "type": "string",
            "enum": ["common", "elite", "boss"]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
